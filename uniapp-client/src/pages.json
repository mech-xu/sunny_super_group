{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^s-(.*)": "@/sheep/components/s-$1/s-$1.vue",
      "^su-(.*)": "@/sheep/ui/su-$1/su-$1.vue"
    }
  },
  {
	"id": "__UNI__PAGES__",
	"globalStyle": {
		"navigationBarBackgroundColor": "#07c160",
		"navigationBarTextStyle": "white",
		"navigationBarTitleText": "SunnyNow 团购自提",
		"backgroundColor": "#FFFFFF"
	},
	"pages": [
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "首页",
				"enablePullDownRefresh": true,
				"backgroundColor": "#f5f5f5"
			}
		},
		{
			"path": "pages/goods/index",
			"style": {
				"navigationBarTitleText": "商品列表",
				"enablePullDownRefresh": true
			}
		},
		{
			"path": "pages/order/create",
			"style": {
				"navigationBarTitleText": "创建订单",
				"backgroundColor": "#f5f5f5"
			}
		},
		{
			"path": "sheep/u-ajax/order/detail",
			"style": {
				"navigationBarTitleText": "订单详情",
				"backgroundColor": "#f5f5f5"
			}
		},
		{
			"path": "pages/user/index",
			"style": {
				"navigationBarTitleText": "我的",
				"backgroundColor": "#f5f5f5"
			}
		}
	],
	"subPackages": [],
	"preloadRule": {
		"pages/index/index": {
			"network": "all",
			"packages": ["common"]
		}
	},
	" tabBar": {
		"color": "#666666",
		"selectedColor": "#07c160",
		"backgroundColor": "#ffffff",
		"borderStyle": "black",
		"list": [
			{
				"pagePath": "pages/index/index",
				"text": "首页",
				"iconPath": "static/images/tabbar/home.png",
				"selectedIconPath": "static/images/tabbar/home-active.png"
			},
			{
				"pagePath": "pages/goods/index",
				"text": "商品",
				"iconPath": "static/images/tabbar/category.png",
				"selectedIconPath": "static/images/tabbar/category-active.png"
			},
			{
				"pagePath": "pages/order/create",
				"text": "我的订单",
				"iconPath": "static/images/tabbar/cart.png",
				"selectedIconPath": "static/images/tabbar/cart-active.png"
			},
			{
				"pagePath": "pages/user/index",
				"text": "我的",
				"iconPath": "static/images/tabbar/profile.png",
				"selectedIconPath": "static/images/tabbar/profile-active.png"
			}
		]
	}
}
