{
  "name": "sunnynow-local",
  "version": "1.0.0",
  "description": "SunnyNow local development environment",
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "preview": "cd frontend && npm run preview",
    "lint": "cd frontend && eslint . --ext .js,.vue",
    "lint:fix": "cd frontend && eslint . --ext .js,.vue --fix",
    "format": "prettier --write .",
    "test": "echo \"No tests configured\"",
    "ci": "npm run lint && npm run test && npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "eslint": "^8.0.0",
    "prettier": "^2.8.0"
  }
}