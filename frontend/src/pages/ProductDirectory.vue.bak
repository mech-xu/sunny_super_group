<template>
  <div class="product-directory iphone-14-container">
    <div class="iphone-frame">
      <div class="notch"></div>
      
      <div class="page-content">
        <header class="page-header">
          <div class="header-content">
            <button @click="goBack" class="back-btn">← 返回</button>
            <h1>产品目录</h1>
            <button @click="logout" class="logout-btn">退出登录</button>
          </div>
          <p>欢迎回来，{{ currentUser?.nickname }}</p>
        </header>
        
        <div class="product-grid">
          <div 
            v-for="product in products" 
            :key="product.id" 
            class="product-card"
          >
            <div class="product-image">
              <img :src="product.image || '/placeholder-product.jpg'" :alt="product.name" />
            </div>
            <div class="product-info">
              <h3>{{ product.name }}</h3>
              <p class="price">¥{{ product.price }}</p>
              <p class="stock">库存: {{ product.stock }}</p>
              <p class="description">{{ product.description || '暂无描述' }}</p>
            </div>
            <div class="product-actions">
              <button 
                @click="toggleFavorite(product.id)"
                :class="{ favorite: isFavorite(product.id) }"
                class="favorite-btn"
              >
                {{ isFavorite(product.id) ? '❤️ 已收藏' : '🤍 收藏' }}
              </button>
              <button @click="addToCart(product)" class="add-to-cart-btn">加入购物车</button>
            </div>
          </div>
        </div>
        
        <div class="cart-summary">
          <div class="cart-info">
            <p>购物车: {{ cartItemCount }} 件商品</p>
            <p>总计: ¥{{ cartTotalPrice }}</p>
          </div>
          <button @click="proceedToCheckout" class="checkout-btn">提交订单</button>
        </div>
      </div>
      
      <div class="home-indicator"></div>
    </div>
    
    <!-- 购物车弹窗 -->
    <div v-if="showCartModal" class="modal-overlay">
      <div class="modal-content">
        <h3>购物车</h3>
        <div class="cart-items">
          <div 
            v-for="item in cartItems" 
            :key="item.productId" 
            class="cart-item"
          >
            <div class="item-info">
              <h4>{{ getProductById(item.productId).name }}</h4>
              <p>¥{{ getProductById(item.productId).price }}</p>
            </div>
            <div class="quantity-controls">
              <button @click="decreaseQuantity(item.productId)">-</button>
              <span>{{ item.quantity }}</span>
              <button @click="increaseQuantity(item.productId)">+</button>
            </div>
            <button @click="removeFromCart(item.productId)" class="remove-btn">删除</button>
          </div>
        </div>
        <div class="cart-total">
          <p>总计: ¥{{ cartTotalPrice }}</p>
        </div>
        <div class="modal-actions">
          <button @click="closeCartModal" class="cancel-btn">继续购物</button>
          <button @click="proceedToCheckout" class="confirm-btn">提交订单</button>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, onMounted } from 'vue';
import { useRouter } from 'vue-router';
import { api } from '../api';

// 使用ref定义响应式状态
const currentUser = ref(null);
const products = ref([]);
const favorites = ref([]);
const cart = ref({}); // { productId: quantity }
const showCartModal = ref(false);

// 计算属性
const cartItemCount = computed(() => {
  return Object.values(cart.value).reduce((sum, qty) => sum + qty, 0);
});

const cartTotalPrice = computed(() => {
  let total = 0;
  for (const [productId, quantity] of Object.entries(cart.value)) {
    const product = getProductById(parseInt(productId));
    if (product) {
      total += product.price * quantity;
    }
  }
  return parseFloat(total).toFixed(2);
});

const cartItems = computed(() => {
  return Object.entries(cart.value).map(([productId, quantity]) => ({
    productId: parseInt(productId),
    quantity
  }));
});

// 方法定义
const toggleFavorite = (productId) => {
  const index = favorites.value.indexOf(productId);
  if (index === -1) {
    favorites.value.push(productId);
  } else {
    favorites.value.splice(index, 1);
  }
  localStorage.setItem('favorites', JSON.stringify(favorites.value));
};

const isFavorite = (productId) => {
  return favorites.value.includes(productId);
};

const addToCart = (product) => {
  // 检查库存是否充足
  const currentQty = cart.value[product.id] || 0;
  if (currentQty >= product.stock) {
    alert('库存不足！');
    return;
  }
  
  // 添加到购物车或增加数量
  cart.value[product.id] = currentQty + 1;
  saveCart();
};

const removeFromCart = (productId) => {
  delete cart.value[productId];
  saveCart();
};

const increaseQuantity = (productId) => {
  const product = getProductById(productId);
  const currentQty = cart.value[productId] || 0;
  
  if (currentQty >= product.stock) {
    alert('库存不足！');
    return;
  }
  
  cart.value[productId] = currentQty + 1;
  saveCart();
};

const decreaseQuantity = (productId) => {
  const currentQty = cart.value[productId] || 0;
  if (currentQty > 1) {
    cart.value[productId] = currentQty - 1;
  } else {
    delete cart.value[productId];
  }
  saveCart();
};

const saveCart = () => {
  localStorage.setItem('cart', JSON.stringify(cart.value));
};

const getProductById = (productId) => {
  return products.value.find(p => p.id === productId);
};

const goToCheckout = () => {
  showCartModal.value = true;
};

const closeCartModal = () => {
  showCartModal.value = false;
};

const router = useRouter();

const proceedToCheckout = async () => {
  // 检查购物车是否为空
  if (Object.keys(cart.value).length === 0) {
    alert('购物车为空，请先添加商品');
    return;
  }
  
  // 关闭弹窗
  showCartModal.value = false;
  
  // 准备订单数据
  const orderData = {
    cartItems: cartItems.value.map(item => {
      const product = getProductById(item.productId);
      return {
        productId: item.productId,
        productName: product.name,
        price: product.price,
        quantity: item.quantity,
        maxStock: product.stock, // 添加最大库存
        subtotal: product.price * item.quantity,
        cartGoodsFlag: 1 // 标记为已加入购物车的商品
      };
    }),
    totalAmount: parseFloat(cartTotalPrice.value),
    user: currentUser.value
  };
  
  // 跳转到订单详情页面，使用query参数传递数据
  try {
    await router.push({ 
      name: 'OrderPreview', 
      query: { orderData: JSON.stringify(orderData) }
    });
  } catch (error) {
    console.error('路由跳转失败:', error);
  }
};

const logout = () => {
  localStorage.removeItem('currentUser');
  router.push('/');
};

// 添加返回功能
const goBack = () => {
  window.history.go(-1); // 返回上一页
};

// 加载数据
onMounted(async () => {
  // 检查用户是否已登录
  const storedUser = localStorage.getItem('currentUser');
  if (!storedUser) {
    // 如果未登录，重定向到登录页面
    router.push('/');
    return;
  }
  
  currentUser.value = JSON.parse(storedUser);
  
  // 加载产品数据
  try {
    // 模拟产品数据
    products.value = [
      {
        id: 1,
        name: '有机草莓',
        price: 25.00,
        stock: 50,
        description: '新鲜采摘的有机草莓，口感甜美',
        image: '/strawberry.jpg'
      },
      {
        id: 2,
        name: '蓝莓礼盒装',
        price: 35.00,
        stock: 30,
        description: '优质蓝莓，包装精美，适合送礼',
        image: '/blueberry.jpg'
      },
      {
        id: 3,
        name: '多肉植物组合',
        price: 18.00,
        stock: 20,
        description: '多种可爱多肉植物组合，易养活',
        image: '/succulent.jpg'
      },
      {
        id: 4,
        name: '进口牛油果',
        price: 12.00,
        stock: 40,
        description: '来自墨西哥的优质牛油果',
        image: '/avocado.jpg'
      },
      {
        id: 5,
        name: '精品咖啡豆',
        price: 45.00,
        stock: 15,
        description: '埃塞俄比亚精品咖啡豆，香气浓郁',
        image: '/coffee-beans.jpg'
      },
      {
        id: 6,
        name: '蜂蜜柚子茶',
        price: 28.00,
        stock: 25,
        description: '天然蜂蜜搭配新鲜柚子制作而成',
        image: '/honey-tea.jpg'
      }
    ];
  } catch (error) {
    console.error('加载产品失败:', error);
  }
  
  // 加载收藏列表
  favorites.value = JSON.parse(localStorage.getItem('favorites') || '[]');
  
  // 加载购物车数据
  cart.value = JSON.parse(localStorage.getItem('cart') || {});
});
</script>

